From: Andrew Ruder <andrew.ruder@elecsyscorp.com>
Subject: [PATCH] enable cross compilation for expect

This patch was created by running ./configure on a modern Linux machine
and inserting the results into the cross compilation section of
each AC_MSG_CHECKING that bombed out with an error.

Signed-off-by: Andrew Ruder <andrew.ruder@elecsyscorp.com>
---

--- a/configure.in
+++ b/configure.in
@@ -486,7 +486,7 @@ main() {
 ,
 	AC_MSG_RESULT(no)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+	AC_MSG_RESULT(no)
 )
 
 AC_MSG_CHECKING([if any value exists for WNOHANG])
@@ -512,7 +512,8 @@ main() {
 	AC_MSG_RESULT(no)
 	AC_DEFINE(WNOHANG_BACKUP_VALUE, 1)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+	AC_MSG_RESULT(yes)
+	AC_DEFINE(WNOHANG_BACKUP_VALUE, 1)
 )
 
 #
@@ -586,7 +587,7 @@ main()
 	AC_DEFINE(REARM_SIG)
 ,
 	AC_MSG_RESULT(no)
-, AC_MSG_WARN([Expect can't be cross compiled])
+, AC_MSG_RESULT(no)
 )
 
 # HPUX7 has trouble with the big cat so split it
@@ -738,7 +739,7 @@ main()
 ,
         AC_MSG_RESULT(no)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+	AC_MSG_RESULT(no)
 )
 
 # mach systems have include files for unimplemented features
@@ -763,7 +764,9 @@ if test $mach -eq 0 ; then
 ,
         AC_MSG_RESULT(no)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+    AC_DEFINE(HAVE_TERMIO)
+    PTY_TYPE=termios
+	AC_MSG_RESULT(yes)
 )
 
   # now check for the new style ttys (not yet posix)
@@ -786,7 +789,9 @@ if test $mach -eq 0 ; then
   ,
         AC_MSG_RESULT(no)
   ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+        AC_DEFINE(HAVE_TERMIOS)
+        PTY_TYPE=termios
+        AC_MSG_RESULT(yes)
   )
 fi
 
@@ -810,7 +815,7 @@ main() {
 ,
 	AC_MSG_RESULT(no)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+	AC_MSG_RESULT(no)
 )
 
 AC_MSG_CHECKING([if TIOCGWINSZ in termios.h])
@@ -833,7 +838,7 @@ main() {
 ,
 	AC_MSG_RESULT(no)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+	AC_MSG_RESULT(no)
 )
 
 # finally check for Cray style ttys
@@ -855,7 +860,7 @@ main(){
 ,
 	AC_MSG_RESULT(no)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+	AC_MSG_RESULT(no)
 )
 
 #
@@ -887,7 +892,9 @@ AC_HAVE_FUNCS(_getpty)
 AC_HAVE_FUNCS(getpty)
 
 # following test sets SETPGRP_VOID if setpgrp takes 0 args, else takes 2
-AC_FUNC_SETPGRP
+cat >>expect_cf.h <<\_ACEOF
+#define SETPGRP_VOID 1
+_ACEOF
 
 #
 # check for timezones
@@ -908,7 +915,7 @@ main()
 	AC_MSG_RESULT(yes),
 	AC_MSG_RESULT(no)
 ,
-	AC_MSG_ERROR([Expect can't be cross compiled])
+	AC_MSG_RESULT(yes)
 )
 
 
